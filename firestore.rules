rules_version = '2';

// 접근 제어의 전부 (ARCHITECTURE.md §9.6) — 서버 코드가 없으므로 이 규칙이
// 계정별 세이브 격리를 담당한다. 본인 uid 문서만 읽기/쓰기 허용.
// 클라이언트 권위 모델이라 값 조작(치팅)은 막지 않는다 — 형태 검증만 한다.
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 봉투 형태 검증 — 필드 3개 외 임의 데이터 저장(스토리지 남용) 차단
    function isEnvelope() {
      let d = request.resource.data;
      return d.keys().hasOnly(['version', 'updatedAt', 'save'])
        && d.version is int
        && d.save is map;
    }

    // users/{uid} = { version, updatedAt, save } — 계정당 세이브 1문서
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isEnvelope();

      // 충돌 해결에서 밀린 세이브 보존 (§9.3) — 실수 복구용
      match /discarded/{epoch} {
        allow read, write: if isOwner(userId) && isEnvelope();
      }
    }

    // ── 닉네임 (§9.8) — 공개 식별자, 추후 랭킹용 ──

    // profiles/{uid} = { uid, nickname, nicknameKey, updatedAt } — 공개 프로필
    // 읽기는 로그인 유저 누구나(랭킹 표시), 쓰기는 본인만.
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['uid', 'nickname', 'nicknameKey', 'updatedAt'])
        && request.resource.data.uid == userId
        && request.resource.data.nickname is string
        && request.resource.data.nicknameKey is string;
    }

    // nicknames/{key} = { uid } — 전역 유일성 잠금 + 역참조
    // 점유는 create(문서 없을 때)로만 — 남의 닉네임 덮어쓰기(update) 불가.
    // 해제(변경 시)는 본인 것만 delete 가능.
    match /nicknames/{key} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if false;
    }
  }
}
